# =============================================================================
# Environment Variables - Restaura Tu Matrimonio Blog
# =============================================================================
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to version control

# =============================================================================
# PUBLIC VARIABLES (exposed to browser)
# These are prefixed with NEXT_PUBLIC_ and are safe to expose
# =============================================================================

# Google Analytics Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Meta (Facebook) Pixel ID for CtaClick/Lead/InitiateCheckout tracking
NEXT_PUBLIC_META_PIXEL_ID=

# Google Search Console verification code
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=google-site-verification-code

# Google AdSense publisher ID (without ca-pub- prefix)
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Public site URL, used to build the absolute PDF download link in the
# lead magnet email
NEXT_PUBLIC_SITE_URL=https://restauratumatrimonio-blog.com

# =============================================================================
# SERVER-ONLY VARIABLES (never exposed to browser)
# These are used in API routes and server-side code only
# =============================================================================

# Contact form endpoint (email service, CRM, etc.)
CONTACT_ENDPOINT=https://your-contact-service-endpoint.example

# Optional: Hotmart webhook secret for affiliate tracking
# HOTMART_WEBHOOK_SECRET=your-webhook-secret

# Brevo API key (private, server-only). Required in production to send the
# lead magnet email. Create it in Brevo under Settings > SMTP & API > API Keys.
BREVO_API_KEY=

# Sender email used for the lead magnet email. Must belong to a domain/sender
# verified in Brevo (Settings > Senders & IP).
BREVO_SENDER_EMAIL=guia.restauratumatrimonio.blog@gmail.com

# Sender display name shown to the recipient.
BREVO_SENDER_NAME="Restaura tu Matrimonio"

# Optional: Brevo list ID used via the Contacts API to save subscribers.
# If unset, only the email is sent (no contact saved to a list).
BREVO_LIST_ID=

# All BREVO_* variables must be configured in the Vercel dashboard
# (Production, Preview, Development as applicable). They should NOT be
# added as GitHub Secrets unless a CI job needs to call Brevo for real,
# which normal test runs must never do.

# =============================================================================
# DEPLOYMENT VARIABLES (set in Vercel dashboard)
# These are typically set in the hosting platform, not in .env files
# =============================================================================

# Vercel deployment URL (automatically set)
# VERCEL_URL=https://your-site.vercel.app